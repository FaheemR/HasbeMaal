<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HasbeMaal.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:HasbeMaal.Mobile.Views"
    Title="HasbeMaal"
    FlyoutBehavior="Flyout"
    FlyoutWidth="320"
    Shell.NavBarIsVisible="True">

    <Shell.FlyoutHeader>
        <Grid Padding="24,28,24,24"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
              RowDefinitions="Auto,Auto"
              RowSpacing="6">
            <Label Text="HasbeMaal" Style="{StaticResource SectionTitle}" FontSize="22" />
            <Label Grid.Row="1" Text="Private family finance" Style="{StaticResource MutedLabel}" />
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Dashboard">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="Dashboard" />
    </FlyoutItem>

    <FlyoutItem Title="Transactions">
        <ShellContent
            x:Name="TransactionsShellContent"
            Title="Transactions"
            Route="Transactions" />
    </FlyoutItem>

    <FlyoutItem Title="Add transaction">
        <ShellContent
            x:Name="ManualEntryShellContent"
            Title="Add transaction"
            Route="ManualEntry" />
    </FlyoutItem>

    <FlyoutItem Title="Budgets">
        <ShellContent
            x:Name="BudgetsShellContent"
            Title="Budgets"
            Route="Budgets" />
    </FlyoutItem>

    <FlyoutItem Title="Goals">
        <ShellContent
            Title="Goals"
            ContentTemplate="{DataTemplate views:GoalsPage}"
            Route="Goals" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent
            x:Name="SettingsShellContent"
            Title="Settings"
            Route="Settings" />
    </FlyoutItem>

</Shell>
