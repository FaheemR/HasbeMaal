<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HasbeMaal.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:HasbeMaal.Mobile.Views"
    Title="HasbeMaal"
    FlyoutBehavior="Disabled"
    FlyoutWidth="320"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="nav_dashboard.svg"
            Route="Dashboard" />

        <ShellContent
            Title="Transactions"
            Icon="nav_transactions.svg"
            Route="Transactions" />

        <ShellContent
            Title="Add"
            Icon="nav_add.svg"
            Route="ManualEntry" />

        <Tab Title="Planning"
             Icon="nav_planning.svg"
             Route="Planning">
            <ShellContent
                Title="Budgets"
                Route="Budgets" />

            <ShellContent
                Title="Goals"
                Route="Goals" />
        </Tab>

        <ShellContent
            Title="Settings"
            Icon="nav_settings.svg"
            Route="Settings" />
    </TabBar>

</Shell>
