<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#135B45</Color>
    <Color x:Key="PrimarySoft">#DDEDE6</Color>
    <Color x:Key="PrimarySoftDark">#1E3B31</Color>
    <Color x:Key="PrimaryDark">#A7D8BF</Color>
    <Color x:Key="PrimaryDarkText">#0D241B</Color>
    <Color x:Key="Secondary">#EAF3EF</Color>
    <Color x:Key="SecondaryDarkText">#B8DEC9</Color>
    <Color x:Key="Tertiary">#A8642A</Color>
    <Color x:Key="TertiarySoft">#F6E7D3</Color>
    <Color x:Key="Info">#2E6F7D</Color>
    <Color x:Key="InfoSoft">#DCECEF</Color>

    <Color x:Key="AppBackground">#F4F1E8</Color>
    <Color x:Key="AppBackgroundDark">#0B1411</Color>
    <Color x:Key="Surface">#FEFCF6</Color>
    <Color x:Key="SurfaceElevated">#FFFFFF</Color>
    <Color x:Key="SurfaceMuted">#EEF5EF</Color>
    <Color x:Key="SurfaceWarm">#FBF1E3</Color>
    <Color x:Key="SurfaceInfo">#EDF6F7</Color>
    <Color x:Key="SurfaceDark">#14221C</Color>
    <Color x:Key="SurfaceElevatedDark">#1B2D25</Color>
    <Color x:Key="SurfaceMutedDark">#23372F</Color>
    <Color x:Key="SurfaceWarmDark">#3A2B1D</Color>
    <Color x:Key="SurfaceInfoDark">#17333A</Color>
    <Color x:Key="Ink">#10221A</Color>
    <Color x:Key="InkMuted">#5F7167</Color>
    <Color x:Key="InkMutedDark">#B8C8BE</Color>
    <Color x:Key="BorderSubtle">#D9E4DC</Color>
    <Color x:Key="BorderSubtleDark">#334A3E</Color>
    <Color x:Key="BorderStrong">#B8C8BE</Color>
    <Color x:Key="BorderStrongDark">#4C6255</Color>
    <Color x:Key="Accent">#A8642A</Color>
    <Color x:Key="AccentSoft">#F6E7D3</Color>
    <Color x:Key="Danger">#B3261E</Color>
    <Color x:Key="DangerSoft">#FCE7E4</Color>
    <Color x:Key="Transparent">Transparent</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#B06A2B</Color>
    <Color x:Key="MidnightBlue">#13231B</Color>
    <Color x:Key="OffBlack">#0F1713</Color>

    <Color x:Key="Gray100">#EDF4EE</Color>
    <Color x:Key="Gray200">#D9E3DA</Color>
    <Color x:Key="Gray300">#B8C8BE</Color>
    <Color x:Key="Gray400">#8FA195</Color>
    <Color x:Key="Gray500">#617166</Color>
    <Color x:Key="Gray600">#35463B</Color>
    <Color x:Key="Gray900">#13231B</Color>
    <Color x:Key="Gray950">#0F1713</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource PrimarySoft}"/>
    <SolidColorBrush x:Key="PrimarySoftDarkBrush" Color="{StaticResource PrimarySoftDark}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="AppBackgroundDarkBrush" Color="{StaticResource AppBackgroundDark}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevated}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}"/>
    <SolidColorBrush x:Key="SurfaceElevatedDarkBrush" Color="{StaticResource SurfaceElevatedDark}"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMuted}"/>
    <SolidColorBrush x:Key="SurfaceMutedDarkBrush" Color="{StaticResource SurfaceMutedDark}"/>
    <SolidColorBrush x:Key="SurfaceWarmBrush" Color="{StaticResource SurfaceWarm}"/>
    <SolidColorBrush x:Key="SurfaceWarmDarkBrush" Color="{StaticResource SurfaceWarmDark}"/>
    <SolidColorBrush x:Key="SurfaceInfoBrush" Color="{StaticResource SurfaceInfo}"/>
    <SolidColorBrush x:Key="SurfaceInfoDarkBrush" Color="{StaticResource SurfaceInfoDark}"/>
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}"/>
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMuted}"/>
    <SolidColorBrush x:Key="InkMutedDarkBrush" Color="{StaticResource InkMutedDark}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderSubtleDarkBrush" Color="{StaticResource BorderSubtleDark}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}"/>
    <SolidColorBrush x:Key="BorderStrongDarkBrush" Color="{StaticResource BorderStrongDark}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}"/>
    <SolidColorBrush x:Key="InfoSoftBrush" Color="{StaticResource InfoSoft}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoft}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>