<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HasbeMaal.Presentation.ViewModels;assembly=HasbeMaal.Presentation"
             x:Class="HasbeMaal.Mobile.Views.TransactionsPage"
             x:DataType="vm:TransactionsViewModel"
             SafeAreaEdges="Container, Container, Container, SoftInput"
             Title="Transactions">
    <Grid RowDefinitions="Auto,Auto,*" Style="{StaticResource PageListLayout}">
        <VerticalStackLayout Style="{StaticResource PageHeaderLayout}">
            <Label Text="LEDGER" Style="{StaticResource EyebrowLabel}" />
            <Label Text="Transactions" Style="{StaticResource PageTitle}" />
            <Label Text="Grouped by month with clear amounts, dates, and direction." Style="{StaticResource PageSubtitle}" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                Style="{StaticResource LoadingStateBorder}"
                IsVisible="{Binding IsLoading}">
            <HorizontalStackLayout Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   VerticalOptions="Center" />
                <VerticalStackLayout Spacing="2">
                    <Label Text="Opening local ledger" Style="{StaticResource ChipLabel}" />
                    <Label Text="Grouping entries by month and category." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <Border Style="{StaticResource EmptyAffordanceBorder}"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="LEDGER READY" Style="{StaticResource EyebrowLabel}" />
                        <Label Text="No transactions yet" Style="{StaticResource SectionTitle}" />
                        <Label Text="Manual entries and local imports will appear here." Style="{StaticResource MutedLabel}" />
                        <Button Text="Add first entry"
                                Clicked="OnAddEntryClicked" />
                    </VerticalStackLayout>
                </Border>
            </CollectionView.EmptyView>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:TransactionGroupViewModel">
                    <Label Text="{Binding Title}"
                           Padding="0,18,0,8"
                           Style="{StaticResource SectionTitle}" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TransactionListItemViewModel">
                    <Border Style="{StaticResource CardBorder}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                            <Label Text="{Binding Merchant}" Style="{StaticResource SectionTitle}" FontSize="16" LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource SectionTitle}" FontSize="16" HorizontalTextAlignment="End" />
                            <Label Grid.Row="1" Text="{Binding OccurredOn}" Style="{StaticResource MutedLabel}" />
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource PillBorder}">
                                <Label Text="{Binding DirectionText}" Style="{StaticResource ChipLabel}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>