<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HasbeMaal.Presentation.ViewModels;assembly=HasbeMaal.Presentation"
             x:Class="HasbeMaal.Mobile.Views.TransactionsPage"
             x:DataType="vm:TransactionsViewModel"
             Title="Transactions">
    <Grid Padding="24" RowDefinitions="Auto,*">
        <VerticalStackLayout Spacing="8">
            <Label Text="Transactions" FontSize="28" FontAttributes="Bold" />
            <Label Text="Grouped by month and category." />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        Margin="0,16,0,0"
                        ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="0,32" Spacing="8">
                    <Label Text="No transactions yet" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Manual entries and imports will appear here." />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:TransactionGroupViewModel">
                    <Label Text="{Binding Title}"
                           Padding="0,18,0,8"
                           FontAttributes="Bold" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TransactionListItemViewModel">
                    <Grid Padding="0,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Text="{Binding Merchant}" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="{Binding AmountText}" />
                        <Label Grid.Row="1" Text="{Binding OccurredOn}" FontSize="12" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding DirectionText}" FontSize="12" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>