<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HasbeMaal.Presentation.ViewModels;assembly=HasbeMaal.Presentation"
             x:Class="HasbeMaal.Mobile.Views.BudgetsPage"
             x:DataType="vm:BudgetsViewModel"
             Title="Budgets">
    <Grid Padding="24" RowDefinitions="Auto,*">
        <VerticalStackLayout Spacing="8">
            <Label Text="Budgets" FontSize="28" FontAttributes="Bold" />
            <Label Text="Monthly category progress appears here after budget data is available." />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        Margin="0,16,0,0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="0,32" Spacing="8">
                    <Label Text="No budget progress yet" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Budget categories and monthly spending totals will appear here." />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:BudgetProgressItemViewModel">
                    <Grid Padding="0,12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding CategoryName}" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding CategoryTypeText}" FontSize="12" />
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                            <Label Text="{Binding SpentText}" />
                            <Label Grid.Column="1" Text="{Binding LimitText}" />
                        </Grid>
                        <ProgressBar Grid.Row="2" Progress="{Binding Progress}" />
                        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                            <Label Text="{Binding RemainingText}" FontSize="12" />
                            <Label Grid.Column="1" Text="{Binding StatusText}" FontSize="12" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>