<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HasbeMaal.Presentation.ViewModels;assembly=HasbeMaal.Presentation"
             x:Class="HasbeMaal.Mobile.Views.SettingsPage"
             x:DataType="vm:SmsPermissionConsentViewModel"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Style="{StaticResource PageContentLayout}">
            <VerticalStackLayout Style="{StaticResource PageHeaderLayout}">
                <Label Text="Settings" Style="{StaticResource PageTitle}" />
                <Label Text="Privacy and local device controls." Style="{StaticResource PageSubtitle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Style="{StaticResource CardContentLayout}" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="Historical SMS access" Style="{StaticResource SectionTitle}" />
                        <Border Grid.Column="1"
                                Style="{StaticResource PillBorder}">
                            <Label Text="{Binding StatusText}" Style="{StaticResource ChipLabel}" />
                        </Border>
                    </Grid>
                    <Label Text="Optional Android permission for reading existing SMS messages locally on this device. HasbeMaal does not store or transmit raw SMS. You can deny access and revoke it later from app settings." Style="{StaticResource MutedLabel}" />
                    <VerticalStackLayout Spacing="10">
                        <Button Text="Allow SMS access"
                                Command="{Binding RequestPermissionCommand}"
                                IsEnabled="{Binding CanRequestPermission}" />
                        <Button Text="Open app settings"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenAppSettingsCommand}"
                                IsEnabled="{Binding CanOpenAppSettings}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Style="{StaticResource CardContentLayout}" Spacing="12">
                    <Label Text="Local data" Style="{StaticResource SectionTitle}" />
                    <Label Text="Delete local transactions, budgets, imports, and diagnostic remnants stored on this device." Style="{StaticResource MutedLabel}" />
                    <Button x:Name="DeleteLocalDataButton"
                            Text="Delete local data"
                            Style="{StaticResource DangerButton}"
                            Clicked="OnDeleteLocalDataClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>