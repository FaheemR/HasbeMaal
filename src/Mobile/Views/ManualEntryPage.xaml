<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HasbeMaal.Presentation.ViewModels;assembly=HasbeMaal.Presentation"
             x:Class="HasbeMaal.Mobile.Views.ManualEntryPage"
             x:DataType="vm:ManualTransactionEntryViewModel"
             Title="Add Transaction">
    <ScrollView>
        <VerticalStackLayout Style="{StaticResource PageContentLayout}">
            <VerticalStackLayout Style="{StaticResource PageHeaderLayout}">
                <Label Text="Add transaction" Style="{StaticResource PageTitle}" />
                <Label Text="Create a structured entry without storing raw message content." Style="{StaticResource PageSubtitle}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Style="{StaticResource CardContentLayout}" Spacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Amount" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding Amount}"
                               Keyboard="Numeric"
                               Placeholder="Amount" />
                        <Label Text="{Binding AmountError}" Style="{StaticResource ErrorLabel}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Merchant or note" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding Merchant}"
                               Placeholder="Merchant or note" />
                        <Label Text="{Binding MerchantError}" Style="{StaticResource ErrorLabel}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Category" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding Category}"
                               Placeholder="Category" />
                        <Label Text="{Binding CategoryError}" Style="{StaticResource ErrorLabel}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Date" Style="{StaticResource FieldLabel}" />
                        <DatePicker Date="{Binding OccurredOn}" />
                    </VerticalStackLayout>

                    <Border Style="{StaticResource InsetPanelBorder}">
                        <HorizontalStackLayout Spacing="12">
                            <CheckBox IsChecked="{Binding IsCredit}" />
                            <Label Text="Money received" Style="{StaticResource ChipLabel}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Button Text="Save entry" Command="{Binding SaveCommand}" />
            <Label Text="{Binding SaveStatusMessage}"
                   Style="{StaticResource ChipLabel}"
                   IsVisible="{Binding HasSaveStatusMessage}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>